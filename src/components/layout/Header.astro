---
interface Props {
  section?: string;
}

const { section } = Astro.props;

const links = [
  { label: 'Contractes', href: '/contractes', id: 'contractes' },
  { label: 'Subvencions', href: '/subvencions', id: 'subvencions' },
  { label: 'Salaris', href: '/salaris', id: 'salaris' },
  { label: 'Viatges', href: '/viatges', id: 'viatges' },
  { label: 'Corrupció', href: '/corrupcio', id: 'corrupcio', wip: true },
];

function linkClass(id: string, wip?: boolean): string {
  if (wip) return 'text-gray-600 text-sm cursor-default';
  const isActive = section === id;
  if (isActive) return 'text-white font-medium text-sm';
  return 'text-gray-400 hover:text-white text-sm transition-colors';
}
---

<header class="fixed top-0 inset-x-0 z-50 bg-gray-950 border-b border-gray-800">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <span class="text-white font-bold text-lg tracking-tight">govern</span>
    </a>

    <ul class="hidden md:flex items-center gap-5">
      {links.map((link) => (
        <li>
          <a href={link.href} class={linkClass(link.id, link.wip)}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 text-gray-400 hover:text-white" aria-label="Obrir menú">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
  </nav>

  <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" />
  <div class="md:hidden hidden peer-checked:block bg-gray-950 border-t border-gray-800">
    <ul class="flex flex-col px-4 py-2 gap-0">
      {links.map((link) => (
        <li>
          <a href={link.href} class={`block py-3 px-3 ${linkClass(link.id, link.wip)}`}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>
