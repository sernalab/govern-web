---
import type { Anomalia } from '@lib/types';
import Badge from '@components/ui/Badge.astro';

interface Props {
  anomalia: Anomalia;
}

const { anomalia } = Astro.props;

const severityStyles = {
  alta: {
    border: 'border-l-red-500',
    bg: 'bg-red-50',
    text: 'text-red-600',
    label: 'Alta',
  },
  mitjana: {
    border: 'border-l-amber-500',
    bg: 'bg-amber-50',
    text: 'text-amber-600',
    label: 'Mitjana',
  },
  baixa: {
    border: 'border-l-blue-500',
    bg: 'bg-blue-50',
    text: 'text-blue-600',
    label: 'Baixa',
  },
};

const style = severityStyles[anomalia.gravetat];

const tipusLabels: Record<string, string> = {
  fraccionament: 'Fraccionament',
  concentracio: 'Concentració',
};

// Extract key evidence facts
const evidencia = anomalia.evidencia || {};
const evidenceFacts: { label: string; value: string }[] = [];

if (evidencia.num_contractes) {
  evidenceFacts.push({
    label: 'Contractes',
    value: String(evidencia.num_contractes),
  });
}
if (evidencia.num_contractes_proveidor) {
  evidenceFacts.push({
    label: 'Contractes proveidor',
    value: `${evidencia.num_contractes_proveidor} / ${evidencia.num_contractes_organ}`,
  });
}
if (evidencia.percentatge_contractes) {
  evidenceFacts.push({
    label: 'Percentatge',
    value: `${evidencia.percentatge_contractes}%`,
  });
}
if (evidencia.import_total) {
  evidenceFacts.push({
    label: 'Import total',
    value: `${Number(evidencia.import_total).toLocaleString('ca-ES', { minimumFractionDigits: 2 })} €`,
  });
}
if (evidencia.llindar) {
  evidenceFacts.push({
    label: 'Llindar',
    value: `${Number(evidencia.llindar).toLocaleString('ca-ES')}EUR`,
  });
}
if (evidencia.any) {
  evidenceFacts.push({ label: 'Any', value: String(evidencia.any) });
}
if (evidencia.percentatge_import) {
  evidenceFacts.push({
    label: '% Import',
    value: `${evidencia.percentatge_import}%`,
  });
}
---

<div
  class={`rounded-lg border-l-4 ${style.border} bg-white shadow-sm border border-gray-200 p-5 transition-colors hover:bg-gray-50`}
>
  {/* Header */}
  <div class="mb-3 flex items-start justify-between gap-3">
    <h3 class="text-base font-semibold text-gray-900">
      {anomalia.titol}
    </h3>
    <div class="flex shrink-0 items-center gap-2">
      <Badge variant="outline" class="text-xs">
        {tipusLabels[anomalia.tipus] || anomalia.tipus}
      </Badge>
      <span
        class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${style.bg} ${style.text}`}
      >
        {style.label}
      </span>
    </div>
  </div>

  {/* Description */}
  <p class="mb-4 text-sm leading-relaxed text-gray-500">
    {anomalia.descripcio}
  </p>

  {/* Evidence summary */}
  {evidenceFacts.length > 0 && (
    <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-4">
      {evidenceFacts.map((fact) => (
        <div class="rounded-md bg-gray-50 border border-gray-100 px-3 py-2">
          <span class="block text-xs text-gray-400">{fact.label}</span>
          <span class="text-sm font-medium text-gray-700">{fact.value}</span>
        </div>
      ))}
    </div>
  )}

  {/* Organ + adjudicatari */}
  {(anomalia.organ || anomalia.adjudicatari) && (
    <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 border-t border-gray-100 pt-3 text-xs text-gray-500">
      {anomalia.organ && (
        <span>
          <span class="text-gray-400">Òrgan:</span> {anomalia.organ}
        </span>
      )}
      {anomalia.adjudicatari && (
        <span>
          <span class="text-gray-400">Adjudicatari:</span>{' '}
          {anomalia.adjudicatari}
        </span>
      )}
    </div>
  )}
</div>
