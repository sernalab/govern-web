---
interface Props {
  label: string;
  value: string;
  trend?: string;
  trendUp?: boolean;
  icon?: string;
  title?: string;
}

const { label, value, trend, trendUp, icon, title } = Astro.props;
const displayLabel = label || title || '';
---

<div class="bg-white border border-gray-200 rounded-lg p-4 sm:p-5 flex flex-col gap-1">
  <span class="text-[11px] sm:text-xs font-medium text-gray-500 truncate">{displayLabel}</span>
  <span class="text-lg sm:text-2xl font-bold text-gray-900 truncate">{value}</span>
  {trend && (
    <span class:list={[
      'text-xs font-medium',
      trendUp ? 'text-emerald-600' : 'text-red-500',
    ]}>
      {trendUp ? '\u2191' : '\u2193'} {trend}
    </span>
  )}
</div>
