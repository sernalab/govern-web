---
interface Props {
  source: string;
  sourceUrl?: string;
  scope: string;
  notes?: string[];
}

const { source, sourceUrl, scope, notes = [] } = Astro.props;

const buildDate = new Date().toLocaleDateString('ca-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="border border-blue-100 bg-blue-50/50 rounded-lg px-4 py-3 text-xs text-blue-900 space-y-1.5">
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
    <span class="flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-blue-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <strong>Font:</strong>
      {sourceUrl ? (
        <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="underline hover:text-blue-700 transition-colors">
          {source}
        </a>
      ) : (
        <span>{source}</span>
      )}
    </span>
    <span class="text-blue-400">·</span>
    <span>{scope}</span>
    <span class="text-blue-400">·</span>
    <span>Consultat el {buildDate}</span>
  </div>
  {notes.length > 0 && (
    <ul class="text-blue-800/80 space-y-0.5 pl-5">
      {notes.map((note) => (
        <li class="list-disc">{note}</li>
      ))}
    </ul>
  )}
</div>
