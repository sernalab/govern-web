---
import DefaultLayout from '@layouts/DefaultLayout.astro';
---

<DefaultLayout
  title="Corrupció"
  description="Secció en construcció — casos de corrupció política a Espanya"
  section="corrupcio"
  keywords="corrupció, casos, política, Espanya, sentències"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 sm:py-32">
    <div class="max-w-lg mx-auto text-center">
      <p class="text-6xl mb-6 select-none">🏗</p>
      <h1 class="text-2xl font-bold text-gray-900 mb-3">Secció en construcció</h1>
      <p class="text-sm text-gray-500 mb-2">
        Estem treballant en una secció de casos de corrupció política a Espanya amb dades judicials verificades.
      </p>
      <p class="text-xs text-gray-400 mb-8">
        Volem assegurar que tota la informació sigui rigorosa, contrastada amb fonts oficials (CENDOJ, CGPJ) i respecti els drets de les persones implicades.
      </p>
      <a
        href="/"
        class="inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded hover:bg-gray-800 transition-colors"
      >
        Tornar a l'inici
      </a>
    </div>
  </div>
</DefaultLayout>
