---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Badge from '@components/ui/Badge.astro';
import DataSourceBanner from '@components/ui/DataSourceBanner.astro';
import SourceCitation from '@components/ui/SourceCitation.astro';
import Timeline from '@components/charts/Timeline.tsx';
import { formatCurrency, formatDate } from '@lib/utils';
import type { CasCorrupcio } from '@lib/types';

import casos from '@data/casos-corrupcion.json';

export function getStaticPaths() {
  const allCasos = casos as CasCorrupcio[];
  return allCasos.map((cas) => ({
    params: { slug: cas.slug },
    props: { cas },
  }));
}

interface Props {
  cas: CasCorrupcio;
}

const { cas } = Astro.props;

function estatToVariant(estat: string): 'condenado' | 'investigado' | 'absuelto' | 'en_curso' {
  const map: Record<string, 'condenado' | 'investigado' | 'absuelto' | 'en_curso'> = {
    condemnat: 'condenado', investigat: 'investigado', absolt: 'absuelto', en_curs: 'en_curso',
  };
  return map[estat] || 'en_curso';
}

function estatToLabel(estat: string): string {
  const map: Record<string, string> = {
    condemnat: 'Condemnat', investigat: 'Investigat', absolt: 'Absolt', en_curs: 'En curs',
  };
  return map[estat] || estat;
}

const timelineEvents: { date: string; title: string; description?: string; type?: 'inicio' | 'investigacion' | 'juicio' | 'sentencia' }[] = [];

if (cas.data_inici) {
  timelineEvents.push({
    date: cas.data_inici,
    title: 'Inici de la investigacio',
    description: `S'inicia la investigacio judicial del ${cas.nom}`,
    type: 'inicio',
  });
}

if (cas.data_sentencia) {
  timelineEvents.push({
    date: cas.data_sentencia,
    title: 'Sentencia',
    description: cas.font_judicial,
    type: 'sentencia',
  });
}

const totalPersones = cas.persones.length;
const condemnatCount = cas.persones.filter(p => p.estat_judicial === 'condemnat').length;
const investigatCount = cas.persones.filter(p => p.estat_judicial === 'investigat').length;
const absoltCount = cas.persones.filter(p => p.estat_judicial === 'absolt').length;
---

<DefaultLayout title={cas.nom} description={cas.descripcio} section="corrupcio" showDisclaimer={true}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 space-y-8">
    <a href="/corrupcio" class="inline-flex items-center text-gray-400 hover:text-gray-700 transition-colors text-xs">
      &larr; Tornar als casos
    </a>

    <section>
      <div class="flex items-start gap-3 flex-wrap mb-3">
        <h1 class="text-2xl font-bold text-gray-900">{cas.nom}</h1>
        <Badge variant={estatToVariant(cas.estat)}>
          {estatToLabel(cas.estat)}
        </Badge>
      </div>
      <p class="text-sm text-gray-500 leading-relaxed mb-4">{cas.descripcio}</p>
      <DataSourceBanner
        source="Elaboracio propia a partir de fonts publiques"
        scope="Dades recopilades manualment — poden contenir errors o no estar actualitzades"
        notes={[
          'Aquesta informacio es orientativa i no constitueix una font judicial oficial',
          'Els imports son estimacions basades en informacio publicada en mitjans i resolucions judicials',
          'Per a informacio judicial verificada, consulteu el CENDOJ (poderjudicial.es)',
        ]}
      />
    </section>

    <section class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="border border-gray-200 rounded-lg p-4">
        <p class="text-xs text-gray-500 mb-1">Comunitat autonoma</p>
        <p class="text-sm font-semibold text-gray-900">{cas.comunitat}</p>
      </div>
      <div class="border border-gray-200 rounded-lg p-4">
        <p class="text-xs text-gray-500 mb-1">Partit politic</p>
        <p class="text-sm font-semibold text-gray-900">{cas.partit}</p>
      </div>
      <div class="border border-gray-200 rounded-lg p-4">
        <p class="text-xs text-gray-500 mb-1">Import estimat</p>
        <p class="text-sm font-semibold text-gray-900">{formatCurrency(cas.import_estimat)}</p>
      </div>
    </section>

    {timelineEvents.length > 0 && (
      <section class="border border-gray-200 rounded-lg bg-white p-5">
        <h2 class="text-sm font-semibold text-gray-700 mb-4">Cronologia judicial</h2>
        <Timeline client:load events={timelineEvents} />
      </section>
    )}

    <section>
      <h2 class="text-lg font-bold text-gray-900 mb-4">Persones implicades</h2>
      <div class="border border-gray-200 rounded-lg bg-white p-5">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
          <div>
            <p class="text-2xl font-bold text-gray-900">{totalPersones}</p>
            <p class="text-xs text-gray-500 mt-1">Total implicats</p>
          </div>
          {condemnatCount > 0 && (
            <div>
              <p class="text-2xl font-bold text-red-600">{condemnatCount}</p>
              <p class="text-xs text-gray-500 mt-1">Condemnats</p>
            </div>
          )}
          {investigatCount > 0 && (
            <div>
              <p class="text-2xl font-bold text-amber-600">{investigatCount}</p>
              <p class="text-xs text-gray-500 mt-1">Investigats</p>
            </div>
          )}
          {absoltCount > 0 && (
            <div>
              <p class="text-2xl font-bold text-emerald-600">{absoltCount}</p>
              <p class="text-xs text-gray-500 mt-1">Absolts</p>
            </div>
          )}
        </div>
        <p class="text-xs text-gray-400 mt-4 text-center">
          No es mostren noms individuals per precaucio legal. Consulteu les fonts judicials oficials per a detalls.
        </p>
      </div>
    </section>

    <section class="border border-gray-200 rounded-lg bg-white p-5">
      <h2 class="text-sm font-semibold text-gray-700 mb-3">Dates clau</h2>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
        {cas.data_inici && (
          <div>
            <dt class="text-xs text-gray-400">Inici investigacio</dt>
            <dd class="text-gray-900">{formatDate(cas.data_inici)}</dd>
          </div>
        )}
        {cas.data_sentencia && (
          <div>
            <dt class="text-xs text-gray-400">Sentencia</dt>
            <dd class="text-gray-900">{formatDate(cas.data_sentencia)}</dd>
          </div>
        )}
      </dl>
    </section>

    {cas.font_judicial && (
      <SourceCitation source={cas.font_judicial} />
    )}
  </div>
</DefaultLayout>
