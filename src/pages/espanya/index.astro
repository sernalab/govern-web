---
import DefaultLayout from '@layouts/DefaultLayout.astro';
---

<DefaultLayout title="Dades d'Espanya" description="Dades obertes d'ambit estatal: subvencions BDNS, legislacio i cataleg nacional" section="espanya">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 space-y-8">
    <section>
      <h1 class="text-2xl font-bold text-gray-900 mb-1">Dades d'Espanya</h1>
      <p class="text-sm text-gray-500 mb-8">
        Fonts d'ambit estatal complementaries a les dades de Catalunya.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <!-- BDNS Subvencions -->
        <a
          href="/espanya/subvencions"
          class="group block border border-gray-200 rounded-lg bg-white p-5 hover:border-gray-400 transition-colors"
        >
          <h2 class="text-sm font-semibold text-gray-900 group-hover:text-blue-600 transition-colors mb-2">Subvencions BDNS</h2>
          <p class="text-xs text-gray-500 mb-3">
            Base de Datos Nacional de Subvenciones. Totes les concessions amb beneficiaris i imports.
          </p>
          <span class="text-xs text-gray-400">Ministeri d'Hisenda</span>
        </a>

        <!-- BOE -->
        <div class="border border-gray-100 rounded-lg bg-gray-50 p-5 opacity-50">
          <div class="flex items-center gap-2 mb-2">
            <h2 class="text-sm font-semibold text-gray-500">Legislacio BOE</h2>
            <span class="text-[10px] text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded">Properament</span>
          </div>
          <p class="text-xs text-gray-400">
            Butlleti Oficial de l'Estat. Legislacio i disposicions.
          </p>
        </div>

        <!-- datos.gob.es -->
        <div class="border border-gray-100 rounded-lg bg-gray-50 p-5 opacity-50">
          <div class="flex items-center gap-2 mb-2">
            <h2 class="text-sm font-semibold text-gray-500">datos.gob.es</h2>
            <span class="text-[10px] text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded">Properament</span>
          </div>
          <p class="text-xs text-gray-400">
            Cataleg de 113.000+ datasets de totes les administracions publiques.
          </p>
        </div>
      </div>
    </section>
  </div>
</DefaultLayout>
