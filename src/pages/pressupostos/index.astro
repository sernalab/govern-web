---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import StatCard from '@components/ui/StatCard.astro';
import DataSourceBanner from '@components/ui/DataSourceBanner.astro';
import BudgetTreemap from '@components/charts/BudgetTreemap.tsx';
import { SOCRATA_DOMAIN, DATASETS } from '@data/datasets';
import { formatCurrency, formatNumber } from '@lib/utils';

const currentYear = new Date().getFullYear();

interface BudgetNode {
  name: string;
  value: number;
}

let totalBudget: number | null = null;
let sectionCount: number | null = null;
let budgetData: BudgetNode[] = [];

try {
  const baseUrl = `https://${SOCRATA_DOMAIN}/resource/${DATASETS.pressupostos_generalitat}.json`;

  const [sectRes, totalRes] = await Promise.all([
    fetch(`${baseUrl}?$select=nom_secci,sum(import_sense_consolidar)&$group=nom_secci&$order=sum_import_sense_consolidar DESC&$limit=50&$where=ingr_s_despesa='D'`),
    fetch(`${baseUrl}?$select=sum(import_sense_consolidar),count(*)&$where=ingr_s_despesa='D'`),
  ]);

  if (sectRes.ok) {
    const sects = await sectRes.json();
    budgetData = sects.map((d: Record<string, string>) => ({
      name: d.nom_secci ?? 'Sense secció',
      value: Number(d.sum_import_sense_consolidar ?? 0),
    }));
    sectionCount = sects.length;
  }

  if (totalRes.ok) {
    const d = await totalRes.json();
    totalBudget = Number(d?.[0]?.sum_import_sense_consolidar ?? 0);
  }
} catch (e) {
  // silenced
}
---

<DefaultLayout title="Pressupostos" description="Pressupostos de la Generalitat de Catalunya" section="pressupostos">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 space-y-8">
    <section>
      <h1 class="text-2xl font-bold text-gray-900 mb-1">Pressupostos</h1>
      <p class="text-sm text-gray-500 mb-4">Pressupostos de la Generalitat de Catalunya</p>
      <DataSourceBanner
        source="Transparència Catalunya (Socrata)"
        sourceUrl="https://analisi.transparenciacatalunya.cat"
        scope="Pressupostos consolidats de despesa de la Generalitat, agrupats per secció"
        notes={[
          'Imports sense consolidar — poden incloure transferències internes entre seccions',
          'La distribució mostra l\'última actualització disponible al portal',
        ]}
      />
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
        <StatCard
          label="Pressupost total (despesa)"
          value={totalBudget !== null ? formatCurrency(totalBudget) : '---'}
        />
        <StatCard
          label="Seccions"
          value={sectionCount !== null ? formatNumber(sectionCount) : '---'}
        />
        <StatCard
          label="Exercici"
          value={String(currentYear)}
        />
      </div>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Distribució per secció</h2>
      {budgetData.length > 0 ? (
        <div class="border border-gray-200 rounded-lg bg-white p-4">
          <BudgetTreemap client:load data={budgetData} />
        </div>
      ) : (
        <div class="text-center py-16 text-gray-400">
          <p>No hi ha dades de pressupost disponibles</p>
        </div>
      )}
    </section>
  </div>
</DefaultLayout>
