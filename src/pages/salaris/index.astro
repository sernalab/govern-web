---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import StatCard from '@components/ui/StatCard.astro';
import DataSourceBanner from '@components/ui/DataSourceBanner.astro';
import SalaryComparator from '@components/sections/SalaryComparator.tsx';
import DataExplorer from '@components/sections/DataExplorer.tsx';
import { SOCRATA_DOMAIN, DATASETS } from '@data/datasets';
import { formatCurrency, formatNumber } from '@lib/utils';

let totalRecords: number | null = null;
let maxSalary: string | null = null;

try {
  const baseUrl = `https://${SOCRATA_DOMAIN}/resource/${DATASETS.retribucions_alts_carrecs}.json`;

  const [statsRes, countRes] = await Promise.all([
    fetch(`${baseUrl}?$select=max(retribucio_anual_prevista)&$order=:id&$limit=1`),
    fetch(`${baseUrl}?$select=count(*)`),
  ]);

  if (statsRes.ok) {
    const d = await statsRes.json();
    maxSalary = d?.[0]?.max_retribucio_anual_prevista ?? null;
  }
  if (countRes.ok) {
    const d = await countRes.json();
    totalRecords = Number(d?.[0]?.count ?? 0);
  }
} catch (e) {
  // silenced
}
---

<DefaultLayout
  title="Retribucions de càrrecs públics"
  description="Retribucions d'alts càrrecs de la Generalitat de Catalunya"
  section="salaris"
  keywords="salaris, retribucions, alts càrrecs, Generalitat, Catalunya"
  jsonLdExtra={{
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: 'Retribucions d\'alts càrrecs de Catalunya',
    description: 'Retribucions anuals previstes dels alts càrrecs de la Generalitat de Catalunya.',
    url: 'https://elteugovern.cat/salaris',
    provider: {
      '@type': 'Organization',
      name: 'Transparència Catalunya',
    },
  }}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 space-y-8">
    <section>
      <h1 class="text-2xl font-bold text-gray-900 mb-1">Retribucions de càrrecs públics</h1>
      <p class="text-sm text-gray-500 mb-4">Alts càrrecs de la Generalitat de Catalunya</p>
      <DataSourceBanner
        source="Transparència Catalunya (Socrata)"
        sourceUrl="https://analisi.transparenciacatalunya.cat"
        scope="Retribucions anuals previstes dels alts càrrecs de la Generalitat"
        notes={[
          'Són retribucions brutes anuals previstes, no salaris nets percebuts',
          'No inclou dietes, indemnitzacions ni retribucions variables',
          'Les dades corresponen a la darrera actualització del portal de transparència',
        ]}
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
        <StatCard
          label="Carrecs registrats"
          value={totalRecords !== null ? formatNumber(totalRecords) : '---'}
        />
        <StatCard
          label="Retribució màxima"
          value={maxSalary ?? '---'}
        />
      </div>
    </section>

    <section>
      <DataExplorer
        client:load
        title="Explorador de retribucions"
        dataset={DATASETS.retribucions_alts_carrecs}
        domain={SOCRATA_DOMAIN}
        dataSource="socrata"
        columns={[
          { key: 'cognoms_nom', label: 'Nom', format: 'text' },
          { key: 'denominacio_lloc', label: 'Càrrec', format: 'text' },
          { key: 'departament', label: 'Departament', format: 'text' },
          { key: 'retribucio_anual_prevista', label: 'Retribució anual', format: 'text' },
        ]}
        searchField="cognoms_nom"
        defaultOrder="retribucio_anual_prevista DESC"
      />
    </section>

    <section>
      <SalaryComparator client:load />
    </section>
  </div>
</DefaultLayout>
