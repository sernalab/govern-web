---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import { getAllEquivalences } from '@lib/equivalences';

const equivalences = getAllEquivalences();
const personal = equivalences.filter(e => e.amount < 10000);
const sous = equivalences.filter(e => e.amount >= 10000 && e.amount < 100000);
const infra = equivalences.filter(e => e.amount >= 100000);

function fmtAmount(n: number): string {
  return n.toLocaleString('ca-ES') + ' €';
}
---

<DefaultLayout
  title="Equivalències"
  description="Com convertim les xifres de despesa pública en coses que tothom entén. Fonts i metodologia."
  keywords="equivalències, despesa pública, beques, escoles, sous, Catalunya"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 space-y-10">
    <section>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Equivalències</h1>
      <p class="text-sm text-gray-500 leading-relaxed">
        Les xifres de despesa pública són difícils d'entendre. Per això convertim cada import en equivalències basades en <strong>dades reals i verificades</strong> de fonts oficials catalanes.
      </p>
    </section>

    <!-- Serveis personals -->
    <section class="border-t border-gray-100 pt-8">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Serveis personals</h2>
      <div class="space-y-3">
        {personal.map(eq => (
          <div class="flex items-center justify-between gap-4 py-2.5 border-b border-gray-50">
            <div class="flex items-center gap-3">
              <span class="text-xl w-8 text-center">{eq.icon}</span>
              <div>
                <p class="text-sm font-medium text-gray-900">{eq.label}</p>
                <p class="text-[11px] text-gray-400">{eq.source}</p>
              </div>
            </div>
            <span class="text-sm font-semibold text-gray-900 tabular-nums shrink-0">{fmtAmount(eq.amount)}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Sous -->
    <section class="border-t border-gray-100 pt-8">
      <h2 class="text-base font-semibold text-gray-900 mb-2">Sous del sector públic</h2>
      <p class="text-xs text-gray-400 mb-4">Retribucions brutes anuals. Font: taules salarials oficials de la Generalitat 2026</p>
      <div class="space-y-3">
        {sous.map(eq => (
          <div class="flex items-center justify-between gap-4 py-2.5 border-b border-gray-50">
            <div class="flex items-center gap-3">
              <span class="text-xl w-8 text-center">{eq.icon}</span>
              <div>
                <p class="text-sm font-medium text-gray-900">{eq.label}</p>
                <p class="text-[11px] text-gray-400">{eq.source}</p>
              </div>
            </div>
            <span class="text-sm font-semibold text-gray-900 tabular-nums shrink-0">{fmtAmount(eq.amount)}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Infraestructures -->
    <section class="border-t border-gray-100 pt-8">
      <h2 class="text-base font-semibold text-gray-900 mb-2">Infraestructures públiques</h2>
      <p class="text-xs text-gray-400 mb-4">Costos mitjans estimats de construcció a Catalunya</p>
      <div class="space-y-3">
        {infra.map(eq => (
          <div class="flex items-center justify-between gap-4 py-2.5 border-b border-gray-50">
            <div class="flex items-center gap-3">
              <span class="text-xl w-8 text-center">{eq.icon}</span>
              <div>
                <p class="text-sm font-medium text-gray-900">{eq.label}</p>
                <p class="text-[11px] text-gray-400">{eq.source}</p>
              </div>
            </div>
            <span class="text-sm font-semibold text-gray-900 tabular-nums shrink-0">{fmtAmount(eq.amount)}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Disclaimer -->
    <section class="border-t border-gray-100 pt-8">
      <div class="border-l-2 border-amber-400 bg-amber-50 pl-4 py-3 pr-4 rounded-r text-xs text-amber-800">
        <p class="font-semibold text-amber-900 mb-1">Fonts i metodologia</p>
        <p>
          Els sous provenen de les <strong>taules salarials oficials de la Generalitat de Catalunya (2026)</strong>,
          consultades via l'API de Transparència Catalunya. La T-jove és el preu oficial de l'ATM 2026 amb bonificació del 50%.
          Els costos d'infraestructures són estimacions basades en licitacions públiques recents.
          Tots els valors són aproximats i poden variar.
        </p>
      </div>
    </section>

    <section class="border-t border-gray-100 pt-8">
      <a href="/cerca" class="inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded hover:bg-gray-800 transition-colors">
        Cerca una entitat i veure equivalències &rarr;
      </a>
    </section>
  </div>
</DefaultLayout>
