---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import StatCard from '@components/ui/StatCard.astro';
import DataSourceBanner from '@components/ui/DataSourceBanner.astro';
import DataExplorer from '@components/sections/DataExplorer.tsx';
import TripProfile from '@components/sections/TripProfile.tsx';
import BarChart from '@components/charts/BarChart';
import { SOCRATA_DOMAIN, DATASETS } from '@data/datasets';
import { formatCurrency, formatNumber } from '@lib/utils';
import { querySocrata, countSocrata } from '@lib/api/socrata';

interface TripRow {
  destinaci: string;
  total_despeses: string;
  nom_i_cognoms: string;
  c_rrec: string;
  departament: string;
  motiu: string;
  inici_viatge: string;
  dietes_i_manutenci: string;
  allotjament: string;
  transport: string;
  altres_despeses: string;
}

function safeNum(v: string | undefined | null): number {
  if (!v) return 0;
  const n = parseFloat(v);
  return isNaN(n) ? 0 : n;
}

let totalTrips = 0;
let totalSpent = 0;
let topDestinations: { label: string; count: number }[] = [];
let topExpensive: TripRow[] = [];
let avgCost = 0;

try {
  const [count, sumRows, destRows, expensive] = await Promise.all([
    countSocrata({ dataset: DATASETS.viatges_oficials }),
    querySocrata<{ total: string }>({
      dataset: DATASETS.viatges_oficials,
      select: 'sum(total_despeses) as total',
      limit: 1,
    }),
    querySocrata<{ destinaci: string; total: string }>({
      dataset: DATASETS.viatges_oficials,
      select: 'destinaci, count(*) as total',
      group: 'destinaci',
      order: 'total DESC',
      where: 'destinaci IS NOT NULL',
      limit: 10,
    }),
    querySocrata<TripRow>({
      dataset: DATASETS.viatges_oficials,
      order: 'total_despeses DESC',
      where: 'total_despeses > 0',
      limit: 5,
    }),
  ]);

  totalTrips = count;
  totalSpent = safeNum(sumRows[0]?.total);
  avgCost = totalTrips > 0 ? totalSpent / totalTrips : 0;
  topDestinations = destRows.map(d => ({
    label: d.destinaci,
    count: parseInt(d.total, 10),
  }));
  topExpensive = expensive;
} catch {
  // silenced
}

const destLabels = topDestinations.map(d => d.label);
const destData = topDestinations.map(d => d.count);
---

<DefaultLayout
  title="Viatges oficials"
  description="On viatgen els alts càrrecs de la Generalitat? Destins, motius i despeses detallades."
  section="viatges"
  keywords="viatges oficials, despeses, alts càrrecs, transparència"
  jsonLdExtra={{
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: 'Viatges oficials dels alts càrrecs de Catalunya',
    description: 'Viatges a l\'estranger dels alts càrrecs de la Generalitat amb despeses desglossades.',
    url: 'https://elteugovern.cat/viatges',
    provider: {
      '@type': 'Organization',
      name: 'Transparència Catalunya',
    },
  }}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 space-y-8">
    <section>
      <h1 class="text-2xl font-bold text-gray-900 mb-1">On viatgen els teus polítics?</h1>
      <p class="text-sm text-gray-500 mb-4">
        Viatges a l'estranger dels alts càrrecs amb despeses desglossades.
      </p>
      <DataSourceBanner
        source="Transparència Catalunya (Socrata)"
        sourceUrl="https://analisi.transparenciacatalunya.cat"
        scope="Viatges oficials a l'estranger dels alts càrrecs i directius de la Generalitat"
        notes={[
          'Inclou dietes, allotjament, transport i altres despeses per viatge',
          'Alguns viatges tenen cost 0 € perquè l\'organització cobreix les despeses',
        ]}
      />
    </section>

    <!-- KPIs -->
    <section>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <StatCard label="Viatges registrats" value={formatNumber(totalTrips)} />
        <StatCard label="Despesa total (2017–2026)" value={formatCurrency(totalSpent)} />
        <StatCard label="Cost mitjà per viatge" value={formatCurrency(avgCost)} />
        <StatCard label="Destinacions" value={formatNumber(topDestinations.length) + '+'} />
      </div>
      <p class="text-[10px] text-gray-400 mt-2">Dades acumulades des del 2017 fins avui</p>
    </section>

    <!-- Charts + top trips -->
    {destLabels.length > 0 && (
      <section>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="border border-gray-200 rounded-lg bg-white p-5">
            <h2 class="text-sm font-semibold text-gray-700 mb-4">Destinacions més freqüents</h2>
            <BarChart
              client:load
              labels={destLabels}
              data={destData}
              label="Viatges"
              horizontal={true}
            />
          </div>

          <div>
            <h2 class="text-sm font-semibold text-gray-700 mb-4">Viatges més cars</h2>
            <div class="space-y-3">
              {topExpensive.map((trip) => {
                const total = safeNum(trip.total_despeses);
                const dietes = safeNum(trip.dietes_i_manutenci);
                const hotel = safeNum(trip.allotjament);
                const transport = safeNum(trip.transport);
                return (
                  <button
                    type="button"
                    class="w-full text-left border border-gray-200 rounded-lg bg-white p-4 hover:border-gray-400 transition-colors cursor-pointer"
                    data-person={trip.nom_i_cognoms}
                    onclick={`window.dispatchEvent(new CustomEvent('trip-profile-open', { detail: '${trip.nom_i_cognoms.replace(/'/g, "\\'")}' }))`}
                  >
                    <div class="flex items-start justify-between gap-3 mb-2">
                      <div class="min-w-0">
                        <p class="text-sm font-medium text-gray-900 truncate">{trip.nom_i_cognoms}</p>
                        <p class="text-xs text-gray-500 truncate">{trip.c_rrec}</p>
                      </div>
                      <span class="text-lg font-bold text-gray-900 tabular-nums shrink-0">
                        {formatCurrency(total)}
                      </span>
                    </div>
                    <p class="text-xs text-gray-700 mb-2 line-clamp-2">{trip.motiu}</p>
                    <div class="flex flex-wrap gap-1.5 text-xs mb-2">
                      <span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{trip.destinaci}</span>
                    </div>
                    {(dietes > 0 || hotel > 0 || transport > 0) && (
                      <div class="flex gap-3 text-xs text-gray-400">
                        {dietes > 0 && <span>Dietes: {formatCurrency(dietes)}</span>}
                        {hotel > 0 && <span>Hotel: {formatCurrency(hotel)}</span>}
                        {transport > 0 && <span>Transport: {formatCurrency(transport)}</span>}
                      </div>
                    )}
                    <p class="text-[10px] text-gray-300 mt-2">Clica per veure tots els viatges d'aquesta persona</p>
                  </button>
                );
              })}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Explorer -->
    <section>
      <DataExplorer
        client:load
        title="Tots els viatges"
        dataset={DATASETS.viatges_oficials}
        domain={SOCRATA_DOMAIN}
        dataSource="socrata"
        columns={[
          { key: 'nom_i_cognoms', label: 'Persona', format: 'text' },
          { key: 'c_rrec', label: 'Càrrec', format: 'text' },
          { key: 'destinaci', label: 'Destinació', format: 'text' },
          { key: 'total_despeses', label: 'Despesa', format: 'currency' },
          { key: 'motiu', label: 'Motiu', format: 'text' },
          { key: 'inici_viatge', label: 'Data', format: 'date' },
        ]}
        searchField="nom_i_cognoms"
        defaultOrder="inici_viatge DESC"
      />
    </section>
  </div>

  <!-- Trip Profile Panel (Preact island) -->
  <TripProfile
    client:load
    domain={SOCRATA_DOMAIN}
    dataset={DATASETS.viatges_oficials}
  />
</DefaultLayout>
