---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import StatCard from '@components/ui/StatCard.astro';
import DataSourceBanner from '@components/ui/DataSourceBanner.astro';
import DataExplorer from '@components/sections/DataExplorer.tsx';
import BarChart from '@components/charts/BarChart';
import { SOCRATA_DOMAIN, DATASETS } from '@data/datasets';
import { formatCurrency, formatNumber, formatCompactNumber } from '@lib/utils';
import { querySocrata, countSocrata } from '@lib/api/socrata';

interface TripRow {
  destinaci: string;
  total_despeses: string;
  nom_i_cognoms: string;
  c_rrec: string;
  departament: string;
  motiu: string;
  inici_viatge: string;
  fi_viatge: string;
  dietes_i_manutenci: string;
  allotjament: string;
  transport: string;
  altres_despeses: string;
  comitiva: string;
  agenda: string;
}

let totalTrips = 0;
let totalSpent = 0;
let topDestinations: { label: string; count: number }[] = [];
let topExpensive: TripRow[] = [];
let avgCost = 0;

try {
  const [count, sumRows, destRows, expensive] = await Promise.all([
    countSocrata({ dataset: DATASETS.viatges_oficials }),
    querySocrata<{ total: string }>({
      dataset: DATASETS.viatges_oficials,
      select: 'sum(total_despeses) as total',
      limit: 1,
    }),
    querySocrata<{ destinaci: string; total: string }>({
      dataset: DATASETS.viatges_oficials,
      select: 'destinaci, count(*) as total',
      group: 'destinaci',
      order: 'total DESC',
      where: 'destinaci IS NOT NULL',
      limit: 10,
    }),
    querySocrata<TripRow>({
      dataset: DATASETS.viatges_oficials,
      order: 'total_despeses DESC',
      limit: 5,
    }),
  ]);

  totalTrips = count;
  totalSpent = sumRows.length > 0 ? parseFloat(sumRows[0].total) || 0 : 0;
  avgCost = totalTrips > 0 ? totalSpent / totalTrips : 0;
  topDestinations = destRows.map(d => ({
    label: d.destinaci,
    count: parseInt(d.total, 10),
  }));
  topExpensive = expensive;
} catch {
  // silenced
}

const destLabels = topDestinations.map(d => d.label);
const destData = topDestinations.map(d => d.count);
---

<DefaultLayout title="Viatges oficials" description="On viatgen els alts carrecs de la Generalitat? Destins, motius i despeses detallades." section="viatges">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 space-y-8">
    <!-- Header -->
    <section>
      <h1 class="text-2xl font-bold text-gray-900 mb-1">On viatgen els teus politics?</h1>
      <p class="text-sm text-gray-500 mb-4">
        Viatges a l'estranger dels alts carrecs de la Generalitat amb despeses desglossades.
      </p>
      <DataSourceBanner
        source="Transparencia Catalunya (Socrata)"
        sourceUrl="https://analisi.transparenciacatalunya.cat"
        scope="Viatges oficials a l'estranger dels alts carrecs i directius de la Generalitat"
        notes={[
          'Inclou dietes, allotjament, transport i altres despeses per viatge',
          'Alguns viatges tenen cost 0€ perque l\'organitzacio cobreix les despeses',
        ]}
      />
    </section>

    <!-- KPIs -->
    <section>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <StatCard label="Viatges registrats" value={formatNumber(totalTrips)} />
        <StatCard label="Despesa total" value={formatCurrency(totalSpent)} />
        <StatCard label="Cost mitja per viatge" value={formatCurrency(avgCost)} />
        <StatCard label="Destinacions" value={formatNumber(topDestinations.length) + '+'} />
      </div>
    </section>

    <!-- Top destinations chart -->
    {destLabels.length > 0 && (
      <section>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="border border-gray-200 rounded-lg bg-white p-5">
            <h2 class="text-sm font-semibold text-gray-700 mb-4">Destinacions mes frequents</h2>
            <BarChart
              client:load
              labels={destLabels}
              data={destData}
              label="Viatges"
              horizontal={true}
            />
          </div>

          <!-- Top expensive trips -->
          <div>
            <h2 class="text-sm font-semibold text-gray-700 mb-4">Viatges mes cars</h2>
            <div class="space-y-3">
              {topExpensive.map((trip) => (
                <div class="border border-gray-200 rounded-lg bg-white p-4">
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-gray-900 truncate">{trip.nom_i_cognoms}</p>
                      <p class="text-xs text-gray-500 truncate">{trip.c_rrec}</p>
                    </div>
                    <span class="text-lg font-bold text-gray-900 tabular-nums shrink-0">
                      {formatCurrency(parseFloat(trip.total_despeses))}
                    </span>
                  </div>
                  <p class="text-xs text-gray-700 mb-2 line-clamp-2">{trip.motiu}</p>
                  <div class="flex flex-wrap gap-1.5 text-xs">
                    <span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{trip.destinaci}</span>
                    <span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{trip.departament}</span>
                  </div>
                  {(parseFloat(trip.dietes_i_manutenci) > 0 || parseFloat(trip.allotjament) > 0 || parseFloat(trip.transport) > 0) && (
                    <div class="flex gap-3 mt-2 text-xs text-gray-400">
                      {parseFloat(trip.dietes_i_manutenci) > 0 && <span>Dietes: {formatCurrency(parseFloat(trip.dietes_i_manutenci))}</span>}
                      {parseFloat(trip.allotjament) > 0 && <span>Hotel: {formatCurrency(parseFloat(trip.allotjament))}</span>}
                      {parseFloat(trip.transport) > 0 && <span>Transport: {formatCurrency(parseFloat(trip.transport))}</span>}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Explorer -->
    <section>
      <DataExplorer
        client:load
        title="Tots els viatges"
        dataset={DATASETS.viatges_oficials}
        domain={SOCRATA_DOMAIN}
        dataSource="socrata"
        columns={[
          { key: 'nom_i_cognoms', label: 'Persona', format: 'text' },
          { key: 'c_rrec', label: 'Carrec', format: 'text' },
          { key: 'destinaci', label: 'Destinacio', format: 'text' },
          { key: 'total_despeses', label: 'Despesa', format: 'currency' },
          { key: 'motiu', label: 'Motiu', format: 'text' },
          { key: 'inici_viatge', label: 'Data', format: 'date' },
        ]}
        searchField="nom_i_cognoms"
        defaultOrder="inici_viatge DESC"
      />
    </section>
  </div>
</DefaultLayout>
