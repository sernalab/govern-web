---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import LegalDisclaimer from '../components/ui/LegalDisclaimer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  section?: string;
  showDisclaimer?: boolean;
}

const {
  title,
  description = 'Transparència i dades públiques de Catalunya',
  section,
  showDisclaimer = false,
} = Astro.props;

const fullTitle = title === 'elteugovern' ? 'elteugovern' : `${title} — elteugovern`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og-image.svg', Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'elteugovern',
  description: 'Transparència i dades públiques de Catalunya',
  url: Astro.site?.href,
};
---

<!doctype html>
<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ca_ES" />
    <meta property="og:site_name" content="elteugovern" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{fullTitle}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-white text-gray-900 flex flex-col">
    <div id="nav-progress"></div>
    <Header section={section} />
    <main class="flex-1 w-full pt-14">
      {showDisclaimer && <LegalDisclaimer />}
      <slot />
    </main>
    <Footer />

    <script>
      document.addEventListener('astro:before-preparation', () => {
        const bar = document.getElementById('nav-progress');
        if (bar) {
          bar.className = 'loading';
        }
      });

      document.addEventListener('astro:after-swap', () => {
        const bar = document.getElementById('nav-progress');
        if (bar) {
          bar.className = 'done';
          setTimeout(() => { bar.className = ''; }, 400);
        }
      });

      document.addEventListener('astro:page-load', () => {
        const bar = document.getElementById('nav-progress');
        if (bar) {
          bar.className = 'done';
          setTimeout(() => { bar.className = ''; }, 400);
        }
      });
    </script>
  </body>
</html>
